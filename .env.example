# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_PARSER_ENABLED=false
GEMINI_EXPLAINER_ENABLED=true

# Elasticsearch Configuration
ES_URL=https://your-elasticsearch-domain.com
ES_USERNAME=your_elasticsearch_username
ES_PASSWORD=your_elasticsearch_password

# Elasticsearch Indices and Fields
ES_INDICES=index1,index2,index3
ES_DATE_FIELD=@timestamp
ES_TIMEZONE=Europe/Lisbon
ES_PUBLISHER_MATCH_MODE=contains
