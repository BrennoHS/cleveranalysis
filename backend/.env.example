# =============================
# Gemini Configuration
# =============================
# Required only if GEMINI_EXPLAINER_ENABLED=true or GEMINI_PARSER_ENABLED=true
GEMINI_API_KEY=your_gemini_api_key

# Explanation (final narrative)
GEMINI_EXPLAINER_ENABLED=false
GEMINI_EXPLAINER_MODEL=gemini-flash-lite-latest
GEMINI_EXPLAINER_MAX_OUTPUT_TOKENS=320

# Parser fallback (optional, only when deterministic parser misses fields)
GEMINI_PARSER_ENABLED=false
GEMINI_PARSER_MODEL=gemini-flash-lite-latest
GEMINI_PARSER_MAX_OUTPUT_TOKENS=256

# =============================
# Elasticsearch / Kibana
# =============================
ES_URL=https://your-kibana-or-es-endpoint/
KIBANA_VERSION=8.2.3
ES_USERNAME=your_username
ES_PASSWORD=your_password

# Comma-separated list of indices/patterns
ES_INDICES=served-impressions*,core-view-events*

# Field mapping
ES_DATE_FIELD=@timestamp
ES_PUBLISHER_FIELD=publisher
ES_SERVED_FIELD=served_impressions
ES_VIEWABLE_FIELD=viewable_impressions

# Timezone used for date interpretation
ES_TIMEZONE=Europe/Lisbon

# Publisher filter mode: contains | exact
ES_PUBLISHER_MATCH_MODE=contains

# Max docs for IP fallback extraction path
ES_IP_FALLBACK_MAX_HITS=8000

# Max docs for behavior metrics (cadence / daily user-volume signals)
ES_BEHAVIOR_MAX_HITS=8000
